# ─── LLM — Two-model strategy ────────────────────────────────────────────────
LLM_PROVIDER=gemini
LLM_MODEL=gemini/gemini-2.0-flash
LLM_API_KEY=your_gemini_api_key_here

# ─── Embeddings ─────────────────────────────────────────────────────────────
# Jina AI provides an OpenAI-compatible API for their v4 embedding model
# Model ID: jina-embeddings-v4
# Context: 32,768 tokens | Multimodal & Highly optimized for semantic search
EMBEDDING_PROVIDER=openai_compatible
EMBEDDING_ENDPOINT=https://api.jina.ai/v1
EMBEDDING_MODEL=jina-embeddings-v4
EMBEDDING_API_KEY=your_jina_api_key_here
EMBEDDING_DIMENSIONS=2048

# ─── Structured Output ────────────────────────────────────────────────────────
# instructor is Cognee's default. json_mode required for Gemini.
STRUCTURED_OUTPUT_FRAMEWORK=instructor
LLM_INSTRUCTOR_MODE=json_mode

# ─── PostgreSQL — relational + pgvector ──────────────────────────────────────
DB_PROVIDER=postgres
DB_HOST=localhost
DB_PORT=5433
DB_USER=persona
DB_PASSWORD=persona
DB_NAME=persona

# ─── Neo4j — graph store ─────────────────────────────────────────────────────
GRAPH_DATABASE_PROVIDER=neo4j
GRAPH_DATABASE_URL=bolt://localhost:7687
GRAPH_DATABASE_USERNAME=neo4j
GRAPH_DATABASE_PASSWORD=persona1

# ─── Cognee ──────────────────────────────────────────────────────────────────
ENABLE_BACKEND_ACCESS_CONTROL=false
CACHING=false

# ─── App ─────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
