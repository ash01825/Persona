# ─── LLM — Two-model strategy ────────────────────────────────────────────────
# Extraction (bulk, per-chunk): fast + cheap
LLM_PROVIDER=gemini
LLM_MODEL=gemini/gemini-2.0-flash
LLM_API_KEY=your_gemini_api_key_here

# ─── Embeddings — Qwen3 8B via Rewind.ai ─────────────────────────────────────
# Rewind.ai provides OpenAI-compatible API for Qwen3-Embedding-8B
# Model ID: qwen/qwen3-embedding-8b
# Context: 32,000 tokens | Price: $0.01/M tokens
EMBEDDING_API_KEY=your_rewind_api_key_here
EMBEDDING_API_BASE=https://api.rewind.ai/v1/
EMBEDDING_MODEL=qwen/qwen3-embedding-8b

# ─── Structured Output ────────────────────────────────────────────────────────
# instructor is Cognee's default. json_mode required for Gemini.
STRUCTURED_OUTPUT_FRAMEWORK=instructor
LLM_INSTRUCTOR_MODE=json_mode

# ─── PostgreSQL — relational + pgvector ──────────────────────────────────────
DB_PROVIDER=postgres
DB_HOST=localhost
DB_PORT=5432
DB_USER=persona
DB_PASSWORD=persona
DB_NAME=persona

# ─── Neo4j — graph store ─────────────────────────────────────────────────────
GRAPH_DATABASE_PROVIDER=neo4j
GRAPH_DATABASE_URL=bolt://localhost:7687
GRAPH_DATABASE_USERNAME=neo4j
GRAPH_DATABASE_PASSWORD=persona

# ─── Cognee ──────────────────────────────────────────────────────────────────
ENABLE_BACKEND_ACCESS_CONTROL=false
CACHING=false

# ─── App ─────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
